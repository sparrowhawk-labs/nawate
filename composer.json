{
    "name": "sparrowhawk-labs/jess",
    "description": "Jess — signed-URL state switching for manual demo/verification in Laravel apps. Recipe-based state, per-session SQLite isolation, zero host-app pollution.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://sparrowhawk-labs.dev",
    "support": {
        "issues": "https://github.com/sparrowhawk-labs/jess/issues",
        "source": "https://github.com/sparrowhawk-labs/jess"
    },
    "authors": [
        {
            "name": "Akihiko Takai",
            "email": "akihiko.takai@yakaze.com",
            "homepage": "https://sparrowhawk-labs.dev",
            "role": "Developer"
        }
    ],
    "keywords": ["laravel", "jess", "demo", "qa", "state-switching", "sparrowhawk-labs"],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "SparrowhawkLabs\\Jess\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SparrowhawkLabs\\Jess\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "SparrowhawkLabs\\Jess\\JessServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
